# Домен берётся из переменной DOMAIN в .env — чтобы он был задан ровно
# в одном месте и не разъезжался с SITE_URL.
#
# Caddy сам получает и продлевает сертификат Let's Encrypt и сам редиректит
# http → https. Обязательные условия: домен уже указывает A-записью на этот
# сервер, а порты 80 и 443 открыты — проверка сертификата идёт через них.
{
	# Почта для Let's Encrypt: туда придёт предупреждение, если продление
	# сломается. Необязательно, но полезно.
	email {$ACME_EMAIL:admin@localhost}

	# По умолчанию — боевой Let's Encrypt. Если сожжён лимит (5 неудач в час)
	# или просто хочется проверить настройку, не тратя попытки, поставь в .env:
	#   ACME_CA=https://acme-staging-v02.api.letsencrypt.org/directory
	# Стейджинг выдаёт сертификат, которому браузер не доверяет, — зато он
	# доказывает, что DNS и порты настроены верно. Потом убери переменную.
	acme_ca {$ACME_CA:https://acme-v02.api.letsencrypt.org/directory}
}

{$DOMAIN} {
	encode gzip

	# В X-Telegram-Init-Data лежит подписанная строка Telegram: id, имя,
	# username и фото человека плюс действующая подпись. В логах ей не место —
	# это и персональные данные, и готовый ключ к API: до истечения срока по
	# такой строке можно действовать от чужого имени. Вырезаем до записи.
	log {
		format filter {
			wrap console
			fields {
				request>headers>X-Telegram-Init-Data delete
				request>headers>Cookie delete
				request>headers>Authorization delete
			}
		}
	}

	# Внутри frontend — nginx: он отдаёт статику и сам проксирует /api на бэкенд.
	#
	# lb_try_duration — про икоту встроенного DNS Docker. Имя frontend
	# резолвится на каждый запрос, и когда 127.0.0.11 подтормаживает, запрос
	# мгновенно превращался в 502 — люди ловили это на регистрации анкеты.
	# Теперь Caddy несколько секунд повторяет попытку: пользователь видит
	# задержку вместо ошибки.
	reverse_proxy frontend:80 {
		lb_try_duration 5s
		lb_try_interval 250ms
	}
}
