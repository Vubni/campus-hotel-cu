# Домен берётся из переменной DOMAIN в .env — чтобы он был задан ровно
# в одном месте и не разъезжался с SITE_URL.
#
# Caddy сам получает и продлевает сертификат Let's Encrypt и сам редиректит
# http → https. Обязательные условия: домен уже указывает A-записью на этот
# сервер, а порты 80 и 443 открыты — проверка сертификата идёт через них.

{$DOMAIN} {
	encode gzip

	# Внутри frontend — nginx: он отдаёт статику и сам проксирует /api на бэкенд.
	reverse_proxy frontend:80
}
