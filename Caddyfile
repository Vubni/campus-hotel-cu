# Caddy сам получает и продлевает сертификат Let's Encrypt для этого домена.
# Обязательные условия: домен уже указывает A-записью на этот сервер,
# а порты 80 и 443 открыты — проверка сертификата идёт через них.

cu.vubni.com {
	encode gzip

	# Внутри frontend — nginx: он отдаёт статику и сам проксирует /api на бэкенд.
	reverse_proxy frontend:80
}
