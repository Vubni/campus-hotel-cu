# Скопируй в .env и заполни: cp .env.example .env
# docker compose подхватывает .env из этой папки автоматически.

# ── Telegram ────────────────────────────────────────────────────────────────
# Токен от @BotFather (/newbot). Без него бот не запустится, а на сайте
# не будет кнопки входа через Telegram. Загрузка фото файлом работает всегда.
TELEGRAM_BOT_TOKEN=

# Ник бота без @ — нужен кнопке «Войти через Telegram» на сайте.
TELEGRAM_BOT_USERNAME=

# Общий секрет между ботом и бэкендом. Придумай любую длинную строку, например:
#   openssl rand -hex 32
BOT_SECRET=

# Адрес сайта — подставляется в ссылки внутри сообщений бота.
SITE_URL=http://localhost:5173
