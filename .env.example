# Скопируй в .env и заполни: cp .env.example .env
# docker compose подхватывает .env из этой папки автоматически.

# ── Telegram ────────────────────────────────────────────────────────────────
# Токен от @BotFather (/newbot). Без него бот не запустится, а на сайте
# не будет кнопки входа через Telegram. Загрузка фото файлом работает всегда.
TELEGRAM_BOT_TOKEN=

# Ник бота без @ — нужен кнопке «Войти через Telegram» на сайте.
TELEGRAM_BOT_USERNAME=

# Общий секрет между ботом и бэкендом. Это НЕ от Telegram — придумай сам:
#   openssl rand -hex 32
# Бот шлёт его в заголовке X-Bot-Secret, бэкенд сверяет. Без него служебные
# ручки бота мог бы дёргать кто угодно и голосовать за других.
BOT_SECRET=

# Кому доступна админка с выгрузкой данных — Telegram ID через запятую.
# Пусто — владельцы сервиса из config.DEFAULT_ADMIN_TELEGRAM_IDS.
# Заполнить стоит, если список админов изменился.
ADMIN_TELEGRAM_IDS=

# Адрес сайта — подставляется в ссылки внутри сообщений бота.
# Нужен только для локального запуска: в проде он собирается из DOMAIN.
SITE_URL=http://localhost:5173

# Короткое имя мини-аппа из @BotFather (/newapp) — часть ссылки
# t.me/<бот>/<короткое имя>. Пусто — считаем мини-апп главным (Main Mini App),
# и ссылка идёт просто на бота: t.me/<бот>?startapp=...
TELEGRAM_MINIAPP_SHORT_NAME=

# ── Общая лента новых анкет ─────────────────────────────────────────────────
# Супергруппа с темами, куда бот пишет о каждой новой анкете.
# Бот должен быть в группе и иметь право писать сообщения.
# Chat id можно указать и без префикса «-100» — бэкенд допишет его сам.
TELEGRAM_FEED_CHAT_ID=4313254279
# Номер темы — это средняя часть ссылки на тему:
# https://t.me/<группа>/<номер темы>/<номер сообщения>
TELEGRAM_FEED_THREAD_ID=97

# Прокси до api.telegram.org — нужен там, где Telegram заблокирован (РФ).
# Через него ходят и бот (long polling), и бэкенд (уведомления, аватарки).
# Форматы:
#   http://user:pass@host:port
#   socks5://user:pass@host:port   (для socks5h резолв DNS на стороне прокси)
# Пусто — ходим напрямую (если сервер за пределами блокировки).
TELEGRAM_PROXY_URL=

# ── Только для прода (docker-compose.prod.yml) ──────────────────────────────
# Домен сайта, БЕЗ https:// и без слэша. Задаётся один раз: на него Caddy
# выпускает сертификат, из него же собирается SITE_URL для бота.
DOMAIN=disk.cu-politic.ru

# Пароль Postgres: openssl rand -hex 16
# Локальный docker-compose.yml его не требует — там пароль по умолчанию.
POSTGRES_PASSWORD=
